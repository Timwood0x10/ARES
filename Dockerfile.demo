FROM golang:1.26-alpine AS builder
WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /bin/ares-demo ./examples/09-full-app/

FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=builder /bin/ares-demo /usr/local/bin/ares-demo
EXPOSE 8080
CMD ["ares-demo"]
